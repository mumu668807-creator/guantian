[
  {
    "id": 1,
    "title": "乾卦",
    "fullName": "乾为天",
    "upperLower": "乾上乾下",
    "judgment": "乾：元，亨，利，贞。",
    "yaoTexts": [
      {
        "title": "初九",
        "text": "潜龙勿用。"
      },
      {
        "title": "九二",
        "text": "见龙在田，利见大人。"
      },
      {
        "title": "九三",
        "text": "君子终日乾乾，夕惕若厉，无咎。"
      },
      {
        "title": "九四",
        "text": "或跃在渊，无咎。"
      },
      {
        "title": "九五",
        "text": "飞龙在天，利见大人。"
      },
      {
        "title": "上九",
        "text": "亢龙有悔。"
      }
    ]
  },
  {
    "id": 2,
    "title": "坤卦",
    "fullName": "坤为地",
    "upperLower": "坤上坤下",
    "judgment": "坤：元亨，利牝马之贞。君子有攸往，先迷后得主。利西南得朋，东北丧朋。安贞吉。",
    "yaoTexts": [
      {
        "title": "初六",
        "text": "履霜，坚冰至。"
      },
      {
        "title": "六二",
        "text": "直方大，不习，无不利。"
      },
      {
        "title": "六三",
        "text": "含章可贞。或从王事，无成有终。"
      },
      {
        "title": "六四",
        "text": "括囊，无咎无誉。"
      },
      {
        "title": "六五",
        "text": "黄裳，元吉。"
      },
      {
        "title": "上六",
        "text": "龙战于野，其血玄黄。"
      }
    ]
  },
  {
    "id": 3,
    "title": "屯卦",
    "fullName": "水雷屯",
    "upperLower": "坎上震下",
    "judgment": "屯：元亨利贞。勿用有攸往，利建侯。",
    "yaoTexts": [
      {
        "title": "初九",
        "text": "磐桓，利居贞，利建侯。"
      },
      {
        "title": "六二",
        "text": "屯如邅如，乘马班如。匪寇，婚媾，女子贞不字，十年乃字。"
      },
      {
        "title": "六三",
        "text": "既鹿无虞，惟入于林中。君子几，不如舍，往吝。"
      },
      {
        "title": "六四",
        "text": "乘马班如，求婚媾，往吉，无不利。"
      },
      {
        "title": "九五",
        "text": "屯其膏，小贞吉，大贞凶。"
      },
      {
        "title": "上六",
        "text": "乘马班如，泣血涟如。"
      }
    ]
  },
  {
    "id": 4,
    "title": "蒙卦",
    "fullName": "山水蒙",
    "upperLower": "艮上坎下",
    "judgment": "蒙：亨。匪我求童蒙，童蒙求我。初噬告，再三渎，渎则不告。利贞。",
    "yaoTexts": [
      {
        "title": "初六",
        "text": "发蒙，利用刑人，用说桎梏；以往吝。"
      },
      {
        "title": "九二",
        "text": "包蒙，吉。纳妇，吉；子克家。"
      },
      {
        "title": "六三",
        "text": "勿用娶女，见金夫，不有躬，无攸利。"
      },
      {
        "title": "六四",
        "text": "困蒙，吝。"
      },
      {
        "title": "六五",
        "text": "童蒙，吉。"
      },
      {
        "title": "上九",
        "text": "击蒙，不利为寇，利御寇。"
      }
    ]
  },
  {
    "id": 5,
    "title": "需卦",
    "fullName": "水天需",
    "upperLower": "坎上乾下",
    "judgment": "需：有孚，光亨，贞吉。利涉大川。",
    "yaoTexts": [
      {
        "title": "初九",
        "text": "需 于郊，利用恒，无咎。"
      },
      {
        "title": "九二",
        "text": "需于沙，小有言，终吉。"
      },
      {
        "title": "九三",
        "text": "需于泥，致寇至。"
      },
      {
        "title": "六四",
        "text": "需于血，出自穴。"
      },
      {
        "title": "九五",
        "text": "需于酒食，贞吉。"
      },
      {
        "title": "上六",
        "text": "入于穴，有不速之客三人 来，敬之终吉。"
      }
    ]
  },
  {
    "id": 6,
    "title": "讼卦",
    "fullName": "天水讼",
    "upperLower": "乾上坎下",
    "judgment": "讼：有孚，窒惕，中吉。终凶。利见大人，不利涉大川。",
    "yaoTexts": [
      {
        "title": "初六",
        "text": "不永所事，小有言，终吉。"
      },
      {
        "title": "九二",
        "text": "不克讼，归而逋，其邑人三百户无眚。"
      },
      {
        "title": "六三",
        "text": "食旧德，贞厉，终吉。或从王事，无成。"
      },
      {
        "title": "九四",
        "text": "不克讼，复自命，渝安贞，吉。"
      },
      {
        "title": "九五",
        "text": "讼，元吉。"
      },
      {
        "title": "上九",
        "text": "或锡之鞶带，终朝三褫之。"
      }
    ]
  },
  {
    "id": 7,
    "title": "师卦",
    "fullName": "地水师",
    "upperLower": "坤上坎下",
    "judgment": "师：贞，丈人吉，无咎。",
    "yaoTexts": [
      {
        "title": "初六",
        "text": "师出以律，否臧凶。"
      },
      {
        "title": "九二",
        "text": "在师，中吉，无咎，王三锡命。"
      },
      {
        "title": "六三",
        "text": "师或舆尸，凶。"
      },
      {
        "title": "六四",
        "text": "师左次，无咎。"
      },
      {
        "title": "六五",
        "text": "田有禽，利执；言，无咎。长子帅师，弟子舆尸，贞凶。"
      },
      {
        "title": "上六",
        "text": "大君有命，开国承家，小人勿用。"
      }
    ]
  },
  {
    "id": 8,
    "title": "比卦",
    "fullName": "水地比",
    "upperLower": "坎上坤下",
    "judgment": "比：吉。原筮，元永贞，无咎。不宁方来，后夫凶。",
    "yaoTexts": [
      {
        "title": "初六",
        "text": "有孚比之，无咎。有孚盈缶，终来有它吉。"
      },
      {
        "title": "六二",
        "text": "比之自内，贞吉。"
      },
      {
        "title": "六三",
        "text": "比之匪人。"
      },
      {
        "title": "六四",
        "text": "外比之，贞吉。"
      },
      {
        "title": "九五",
        "text": "显比，王用三驱，失前禽。邑人不诫，吉。"
      },
      {
        "title": "上六",
        "text": "比之无首，凶。"
      }
    ]
  },
  {
    "id": 9,
    "title": "小畜卦",
    "fullName": "风天小畜",
    "upperLower": "巽上乾下",
    "judgment": "小畜：亨。密云不雨，自我西郊。",
    "yaoTexts": [
      {
        "title": "初九",
        "text": "复自道，何其咎？吉。"
      },
      {
        "title": "九二",
        "text": "牵复，吉。"
      },
      {
        "title": "九三",
        "text": "舆说辐，夫妻反目。"
      },
      {
        "title": "六四",
        "text": "有孚，血去惕出，无咎。"
      },
      {
        "title": "九五",
        "text": "有孚挛如，富以其邻。"
      },
      {
        "title": "上九",
        "text": "既雨既处，尚德载。妇贞厉。月几望，君子征凶。"
      }
    ]
  },
  {
    "id": 10,
    "title": "履卦",
    "fullName": "天泽履",
    "upperLower": "乾上兑下",
    "judgment": "履：履虎尾，不咥人，亨。",
    "yaoTexts": [
      {
        "title": "初九",
        "text": "素履往，无咎。"
      },
      {
        "title": "九二",
        "text": "履道坦坦，幽人贞吉。"
      },
      {
        "title": "六三",
        "text": "眇能视，跛能履。履虎尾，咥人，凶。武人为于大君。"
      },
      {
        "title": "九四",
        "text": "履虎尾，愬愬，终吉。"
      },
      {
        "title": "九五",
        "text": "夬履，贞厉。"
      },
      {
        "title": "上九",
        "text": "视履考祥，其旋元吉。"
      }
    ]
  },
  {
    "id": 11,
    "title": "泰卦",
    "fullName": "地天泰",
    "upperLower": "坤上乾下",
    "judgment": "泰：小往大来，吉亨。",
    "yaoTexts": [
      {
        "title": "初九",
        "text": "拔茅茹，以其汇，征吉。"
      },
      {
        "title": "九二",
        "text": "包荒，用冯河，不遐遗。朋亡，得尚于中行。"
      },
      {
        "title": "九三",
        "text": "无平不陂，无往不复，艰贞无咎。勿恤其孚，于食有福。"
      },
      {
        "title": "六四",
        "text": "翩翩，不富以其邻，不戒以孚。"
      },
      {
        "title": "六五",
        "text": "帝乙归妹，以祉元吉。"
      },
      {
        "title": "上六",
        "text": "城复于隍，勿用师。自邑告命，贞吝。"
      }
    ]
  },
  {
    "id": 12,
    "title": "否卦",
    "fullName": "天地否",
    "upperLower": "乾上坤下",
    "judgment": "否：否之匪人，不利君子贞，大往小来。",
    "yaoTexts": [
      {
        "title": "初六",
        "text": "拔茅茹，以其汇，贞吉，亨。"
      },
      {
        "title": "六二",
        "text": "包承，小人吉，大人否，亨。"
      },
      {
        "title": "六三",
        "text": "包羞。"
      },
      {
        "title": "九四",
        "text": "有命无咎，畴离祉。"
      },
      {
        "title": "九五",
        "text": "休否，大人吉。其亡其亡，系于苞桑。"
      },
      {
        "title": "上九",
        "text": "倾否，先否后喜。"
      }
    ]
  },
  {
    "id": 13,
    "title": "同人卦",
    "fullName": "天火同人",
    "upperLower": "乾上离下",
    "judgment": "同人：同人于野，亨。利涉大川，利君子贞。",
    "yaoTexts": [
      {
        "title": "初九",
        "text": "同人于门，无咎。"
      },
      {
        "title": "六二",
        "text": "同人于宗，吝。"
      },
      {
        "title": "九三",
        "text": "伏戎于莽，升其高陵，三岁不兴。"
      },
      {
        "title": "九四",
        "text": "乘其墉，弗克攻，吉。"
      },
      {
        "title": "九五",
        "text": "同人，先号咷而后笑。大师克相遇。"
      },
      {
        "title": "上九",
        "text": "同人于郊，无悔。"
      }
    ]
  },
  {
    "id": 14,
    "title": "大有卦",
    "fullName": "火天大有",
    "upperLower": "离上乾下",
    "judgment": "大有：元亨。",
    "yaoTexts": [
      {
        "title": "初九",
        "text": "无交害，匪咎，艰则无咎。"
      },
      {
        "title": "九二",
        "text": "大车以载，有攸往，无咎。"
      },
      {
        "title": "九三",
        "text": "公用亨于天子，小人弗克。"
      },
      {
        "title": "九四",
        "text": "匪其彭，无咎。"
      },
      {
        "title": "六五",
        "text": "厥孚交如，威如，吉。"
      },
      {
        "title": "上九",
        "text": "自天佑之，吉无不利。"
      }
    ]
  },
  {
    "id": 15,
    "title": "谦卦",
    "fullName": "地山谦",
    "upperLower": "坤上艮下",
    "judgment": "谦：亨，君子有终。",
    "yaoTexts": [
      {
        "title": "初六",
        "text": "谦谦君子，用涉大川，吉。"
      },
      {
        "title": "六二",
        "text": "鸣谦，贞吉。"
      },
      {
        "title": "九三",
        "text": "劳谦君子，有终，吉。"
      },
      {
        "title": "六四",
        "text": "无不利，㧑谦。"
      },
      {
        "title": "六五",
        "text": "不富以其邻，利用侵伐，无不利。"
      },
      {
        "title": "上六",
        "text": "鸣谦，利用行师，征邑国。"
      }
    ]
  },
  {
    "id": 16,
    "title": "豫卦",
    "fullName": "雷地豫",
    "upperLower": "震上坤下",
    "judgment": "豫：利建侯行师。",
    "yaoTexts": [
      {
        "title": "初六",
        "text": "鸣豫，凶。"
      },
      {
        "title": "六二",
        "text": "介于石，不终日，贞吉。"
      },
      {
        "title": "六三",
        "text": "盱豫，悔。迟有悔。"
      },
      {
        "title": "九四",
        "text": "由豫，大有得。勿疑，朋盍簪。"
      },
      {
        "title": "六五",
        "text": "贞疾，恒不死。"
      },
      {
        "title": "上六",
        "text": "冥豫，成有渝，无咎。"
      }
    ]
  },
  {
    "id": 17,
    "title": "随卦",
    "fullName": "泽雷随",
    "upperLower": "兑上震下",
    "judgment": "随：元亨利贞，无咎。",
    "yaoTexts": [
      {
        "title": "初九",
        "text": "官有渝，贞吉。出门交有功。"
      },
      {
        "title": "六二",
        "text": "系小子，失丈夫。"
      },
      {
        "title": "六三",
        "text": "系丈夫，失小子。随有求，得，利居贞。"
      },
      {
        "title": "九四",
        "text": "随有获，贞凶。有孚，在道以明，何咎？"
      },
      {
        "title": "九五",
        "text": "孚于嘉，吉。"
      },
      {
        "title": "上六",
        "text": "拘系之，乃从维之。王用亨于西山。"
      }
    ]
  },
  {
    "id": 18,
    "title": "蛊卦",
    "fullName": "山风蛊",
    "upperLower": "艮上巽下",
    "judgment": "蛊：元亨，利涉大川。先甲三日，后甲三日。",
    "yaoTexts": [
      {
        "title": "初六",
        "text": "干父之蛊，有子，考无咎，厉终吉。"
      },
      {
        "title": "九二",
        "text": "干母之蛊，不可贞。"
      },
      {
        "title": "九三",
        "text": "干父之蛊，小有晦，无大咎。"
      },
      {
        "title": "六四",
        "text": "裕父之蛊，往见吝。"
      },
      {
        "title": "六五",
        "text": "干父之蛊，用誉。"
      },
      {
        "title": "上九",
        "text": "不事王侯，高尚其事。"
      }
    ]
  },
  {
    "id": 19,
    "title": "临卦",
    "fullName": "地泽临",
    "upperLower": "坤上兑下",
    "judgment": "临：元，亨，利，贞。至于八月有凶。",
    "yaoTexts": [
      {
        "title": "初九",
        "text": "咸临，贞吉。"
      },
      {
        "title": "九二",
        "text": "咸临，吉，无不利。"
      },
      {
        "title": "六三",
        "text": "甘临，无攸利。既忧之，无咎。"
      },
      {
        "title": "六四",
        "text": "至临，无咎。"
      },
      {
        "title": "六五",
        "text": "知临，大君之宜，吉。"
      },
      {
        "title": "上六",
        "text": "敦临，吉，无咎。"
      }
    ]
  },
  {
    "id": 20,
    "title": "观卦",
    "fullName": "风地观",
    "upperLower": "巽上坤下",
    "judgment": "观：盥而不荐，有孚颙若。",
    "yaoTexts": [
      {
        "title": "初六",
        "text": "童观，小人无咎，君子吝。"
      },
      {
        "title": "六二",
        "text": "窥观，利女贞。"
      },
      {
        "title": "六三",
        "text": "观我生，进退。"
      },
      {
        "title": "六四",
        "text": "观国之光，利用宾于王。"
      },
      {
        "title": "九五",
        "text": "观我生，君子无咎。"
      },
      {
        "title": "上九",
        "text": "观其生，君子无咎。"
      }
    ]
  },
  {
    "id": 21,
    "title": "噬嗑卦",
    "fullName": "火雷噬嗑",
    "upperLower": "离上震下",
    "judgment": "噬嗑：亨。利用狱。",
    "yaoTexts": [
      {
        "title": "初九",
        "text": "履校灭趾，无咎。"
      },
      {
        "title": "六二",
        "text": "噬肤灭鼻，无咎。"
      },
      {
        "title": "六三",
        "text": "噬腊肉，遇毒。小吝，无咎。"
      },
      {
        "title": "九四",
        "text": "噬干胏，得金矢。利艰贞，吉。"
      },
      {
        "title": "六五",
        "text": "噬干肉，得黄金。贞厉，无咎。"
      },
      {
        "title": "上九",
        "text": "何校灭耳，凶。"
      }
    ]
  },
  {
    "id": 22,
    "title": "贲卦",
    "fullName": "山火贲",
    "upperLower": "艮上离下",
    "judgment": "贲：亨。小利有所往。",
    "yaoTexts": [
      {
        "title": "初九",
        "text": "贲其趾，舍车而徒。"
      },
      {
        "title": "六二",
        "text": "贲其须。"
      },
      {
        "title": "九三",
        "text": "贲如，濡如，永贞吉。"
      },
      {
        "title": "六四",
        "text": "贲如，皤如，白马翰如，匪寇婚媾。"
      },
      {
        "title": "六五",
        "text": "贲于丘园，束帛戋戋。吝，终吉。"
      },
      {
        "title": "上九",
        "text": "白贲，无咎。"
      }
    ]
  },
  {
    "id": 23,
    "title": "剥卦",
    "fullName": "山地剥",
    "upperLower": "艮上坤下",
    "judgment": "剥：不利有攸往。",
    "yaoTexts": [
      {
        "title": "初六",
        "text": "剥床以足，蔑贞，凶。"
      },
      {
        "title": "六二",
