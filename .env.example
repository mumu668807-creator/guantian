LLM_PROVIDER=deepseek
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Supabase Auth. These are public frontend values; never put service role keys here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional support link. This is public and only controls whether the support link appears.
VITE_SUPPORT_URL=https://your-support-page.example
